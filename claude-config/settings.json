{
  "cleanupPeriodDays": 365,
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "DISABLE_TELEMETRY": "1",
    "DISABLE_ERROR_REPORTING": "1"
  },
  "permissions": {
    "allow": [
      "Bash(*)",
      "Read",
      "Edit",
      "Write",
      "Glob",
      "Grep",
      "Agent",
      "mcp__plugin_everything-claude-code_github__*",
      "mcp__plugin_everything-claude-code_playwright__*",
      "mcp__plugin_everything-claude-code_memory__*",
      "mcp__plugin_everything-claude-code_exa__*",
      "mcp__plugin_everything-claude-code_context7__*",
      "mcp__claude_ai_Gmail__*",
      "mcp__claude_ai_Google_Calendar__*",
      "mcp__claude_ai_Notion__*",
      "mcp__pencil"
    ],
    "deny": [
      "Bash(rm * ~/.ssh*)",
      "Bash(rm * ~/.gnupg*)",
      "Bash(rm * ~/.aws*)",
      "Bash(git push * --force *)",
      "Bash(git push --force *)",
      "~/.ssh/**",
      "~/.gnupg/**",
      "~/.aws/**",
      "**/.env",
      "**/.env.*",
      "**/credentials.json"
    ],
    "defaultMode": "bypassPermissions"
  },
  "model": "claude-fable-5[1m]",
  "enableAllProjectMcpServers": true,
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/Users/nobu/.nvm/versions/node/v24.13.0/bin/node /Users/nobu/claude\\ for\\ me/ops/scripts/set-claude-terminal-title.mjs"
          },
          {
            "type": "command",
            "command": "echo \"# currentTime\\nThe current time is $(date '+%Y年%m月%d日 %H:%M JST').\""
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/Users/nobu/.nvm/versions/node/v24.13.0/bin/node /Users/nobu/claude\\ for\\ me/ops/scripts/session-start.mjs"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/usr/bin/afplay /System/Library/PrivateFrameworks/AXMediaUtilities.framework/Versions/A/Resources/sounds/pluck1.aiff"
          },
          {
            "type": "command",
            "command": "/Users/nobu/.nvm/versions/node/v24.13.0/bin/node /Users/nobu/.claude/hooks/stop/capture-instructions.mjs"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "discord@claude-plugins-official": true,
    "swift-lsp@claude-plugins-official": true,
    "everything-claude-code@everything-claude-code": true
  },
  "extraKnownMarketplaces": {
    "everything-claude-code": {
      "source": {
        "source": "github",
        "repo": "affaan-m/everything-claude-code"
      }
    },
    "claude-code-settings": {
      "source": {
        "source": "github",
        "repo": "feiskyer/claude-code-settings"
      }
    },
    "trailofbits": {
      "source": {
        "source": "github",
        "repo": "trailofbits/skills"
      }
    },
    "claude-plugins-official": {
      "source": {
        "source": "github",
        "repo": "anthropics/claude-plugins-official"
      }
    }
  },
  "alwaysThinkingEnabled": true,
  "voiceEnabled": true,
  "skipDangerousModePermissionPrompt": true,
  "channelsEnabled": true,
  "remoteControlAtStartup": false,
  "appearance": {
    "theme": "dark",
    "terminal": {
      "fontSize": 13,
      "fontFamily": "Monaco, Menlo, 'Courier New'",
      "enableTrueColor": true,
      "linePadding": 2
    },
    "colors": {
      "success": "#10b981",
      "warning": "#f59e0b",
      "error": "#ef4444",
      "info": "#3b82f6",
      "primary": "#06b6d4"
    }
  },
  "cliStyle": {
    "spinner": "dots2",
    "tableStyle": "compact",
    "verbosity": "normal"
  }
}
