{
  "name": "copain-claude-workspace",
  "private": true,
  "description": "COPAIN AI — Notion ハブ & Claude Code 用スクリプト",
  "scripts": {
    "notion:env": "node scripts/notion-env-setup.mjs",
    "notion:verify": "node scripts/notion-verify.mjs",
    "notion:hub": "node scripts/notion-hub-create.mjs",
    "notion:reset": "node scripts/notion-hub-reset.mjs --yes",
    "notion:seed": "node scripts/notion-seed.mjs",
    "pulse:discord": "node scripts/notion-pulse.mjs",
    "discord:test": "node scripts/discord-webhook-test.mjs",
    "bootstrap": "npm run notion:verify && npm run notion:hub && npm run notion:seed && npm run discord:test",
    "notion:sessions:init": "node scripts/notion-sessions-db.mjs",
    "session:log": "node scripts/session-log.mjs",
    "browser:install": "playwright install chromium",
    "browser:daemon": "node scripts/browser-daemon.mjs",
    "weekly:review": "node scripts/weekly-review.mjs",
    "kokkai:fetch": "node scripts/kokkai-fetch.mjs",
    "kokkai:fetch:week": "node scripts/kokkai-fetch.mjs --days 7",
    "kokkai:sync": "node scripts/kokkai-sync.mjs",
    "kokkai:sync:dry": "node scripts/kokkai-sync.mjs --dry-run",
    "loop:morning": "node scripts/autonomous-loop.mjs morning",
    "loop:sync": "node scripts/autonomous-loop.mjs sync",
    "loop:weekly": "node scripts/autonomous-loop.mjs weekly",
    "line:start": "node line-bot/server.mjs",
    "line:dev": "node --watch line-bot/server.mjs",
    "ttyd:start": "bash scripts/start-ttyd.sh",
    "ttyd:stop": "pkill -f ttyd",
    "ttyd:status": "pgrep -fl ttyd && echo 'URL: http://'$(tailscale ip -4)':7681' || echo 'ttyd is not running'",
    "remote:start": "node remote-app/server.mjs",
    "remote:status": "echo 'Launcher: http://'$(tailscale ip -4)':7680' && echo 'Terminal: http://'$(tailscale ip -4)':7681'",
    "notion:extract-tasks": "node scripts/notion-extract-tasks.mjs",
    "notion:nightly-scan": "node scripts/notion-nightly-scan.mjs",
    "linkedin:setup-notion": "node scripts/linkedin-setup-notion.mjs",
    "linkedin:setup": "node scripts/linkedin-setup.mjs",
    "linkedin:generate": "node scripts/linkedin-generate.mjs",
    "linkedin:post": "node scripts/linkedin-post.mjs",
    "linear:setup": "node scripts/linear-setup.mjs",
    "linear:loop": "node scripts/linear-agent-loop.mjs",
    "linear:morning": "node scripts/linear-morning-summary.mjs",
    "morning:post": "node scripts/discord-morning.mjs",
    "morning:reply": "node scripts/discord-morning-reply.mjs",
    "bot:daemon": "node scripts/discord-bot-daemon.mjs"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "@linear/sdk": "^80.0.0",
    "@notionhq/client": "^5.16.0",
    "playwright": "^1.51.0",
    "ws": "^8.20.0"
  },
  "engines": {
    "node": ">=20"
  }
}
