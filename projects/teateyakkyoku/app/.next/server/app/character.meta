{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/character/layout,_N_T_/character/page,_N_T_/character"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/character/__PAGE__",
    "/character",
    "/_index",
    "/_head"
  ]
}